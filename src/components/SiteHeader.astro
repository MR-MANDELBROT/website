---
import { categories } from "../lib/gallery";

interface Props {
  active?: string;
}
const { active } = Astro.props;
const path = Astro.url.pathname;
---

<header class="site-head">
  <div class="wrap head-inner">
    <a class="brand" href="/">Maximilian Marquart</a>
    <nav class="cat-nav" aria-label="Kategorien">
      <a href="/fotografie/" class:list={[{ on: path === "/fotografie/" }]}
        >Alle</a
      >
      {
        categories.map((c) => (
          <a
            href={`/fotografie/${c.slug}/`}
            class:list={[{ on: active === c.slug }]}
          >
            {c.title}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script is:inline>
  // Aktive Kategorie in der horizontal scrollbaren Leiste sichtbar machen.
  // Über getBoundingClientRect statt offsetLeft -> robust, kein Abschneiden.
  (function () {
    var nav = document.querySelector(".cat-nav");
    var on = nav && nav.querySelector("a.on");
    if (!nav || !on) return;
    var delta =
      on.getBoundingClientRect().left - nav.getBoundingClientRect().left - 16;
    nav.scrollLeft += delta;
  })();
</script>

<style>
  .site-head {
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    /* -webkit- zuerst: iOS Safari rendert den Blur sonst NICHT */
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    position: sticky;
    top: 0;
    z-index: 10;
    /* Blur/Hintergrund reicht bis zur Bildschirmkante hinter die
       Statusbar/Dynamic Island; liegt stabil auf dem Sticky-Element */
    padding-top: env(safe-area-inset-top, 0px);
  }

  .head-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
    flex-wrap: wrap;
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .cat-nav {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .cat-nav a {
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--ink-soft);
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .cat-nav a:hover {
    color: var(--ink);
  }

  .cat-nav a.on {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  /* Mobil: dünne, einzeilige Leiste – Kategorien horizontal scrollbar
     (bewährtes Tab-/Chip-Pattern), Scrollbar ausgeblendet. */
  @media (max-width: 560px) {
    .head-inner {
      gap: 0.55rem;
      padding-top: 0.9rem;
      padding-bottom: 0.7rem;
    }
    .cat-nav {
      flex: 1 1 100%;
      flex-wrap: nowrap;
      overflow-x: auto;
      gap: 1.1rem;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-right: 0.5rem;
    }
    .cat-nav::-webkit-scrollbar {
      display: none;
    }
    .cat-nav a {
      flex: 0 0 auto;
      white-space: nowrap;
    }
  }
</style>
