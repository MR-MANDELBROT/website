---
import { categories } from "../lib/gallery";

interface Props {
  active?: string;
}
const { active } = Astro.props;
const path = Astro.url.pathname;
---

<header class="site-head">
  <!-- iOS 26 Liquid Glass: Blur/Hintergrund NICHT auf das sticky-Element
       legen (Safari sampelt dessen Farbe für die Stirn/Kinn-Tönung und die
       Leiste verschiebt sich beim Scrollen). Stattdessen auf ein absolutes
       Kind -> sticky-Element selbst bleibt transparent. -->
  <div class="glass" aria-hidden="true"></div>
  <div class="wrap head-inner">
    <a class="brand" href="/">Maximilian Marquart</a>
    <nav class="cat-nav" aria-label="Kategorien">
      <a href="/fotografie/" class:list={[{ on: path === "/fotografie/" }]}
        >Alle</a
      >
      {
        categories.map((c) => (
          <a
            href={`/fotografie/${c.slug}/`}
            class:list={[{ on: active === c.slug }]}
          >
            {c.title}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script is:inline>
  // Aktive Kategorie bündig zum linken Rand (= zur Marke) ausrichten.
  // WICHTIG: erst nach Layout + Font-Load rechnen, sonst basiert das
  // Scrollen auf noch nicht finalen Positionen (-> auf iOS abgeschnitten).
  (function () {
    function alignActive() {
      var nav = document.querySelector(".cat-nav");
      var on = nav && nav.querySelector("a.on");
      if (!nav || !on) return;
      nav.scrollLeft +=
        on.getBoundingClientRect().left - nav.getBoundingClientRect().left;
    }
    alignActive();
    window.addEventListener("load", alignActive);
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(alignActive);
    }
  })();
</script>

<style>
  .site-head {
    position: sticky;
    top: 0;
    z-index: 10;
    /* Selbst transparent (iOS-26-Tönung). Insets schieben den Inhalt
       unter Dynamic Island / über die Seitenkanten im Querformat. */
    background: transparent;
    padding-top: env(safe-area-inset-top, 0px);
    padding-left: env(safe-area-inset-left, 0px);
    padding-right: env(safe-area-inset-right, 0px);
  }

  /* Visueller Glas-Hintergrund als absolutes Kind: deckt den gesamten
     Header inkl. Safe-Area ab, ohne dass Safari ihn zur Stirn-Tönung
     heranzieht -> kein Verrutschen beim Scrollen. */
  .site-head .glass {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    /* -webkit- zuerst: iOS Safari rendert den Blur sonst NICHT */
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--line);
  }

  .head-inner {
    position: relative;
    z-index: 1; /* Inhalt über dem Glas-Hintergrund */
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
    flex-wrap: wrap;
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .cat-nav {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .cat-nav a {
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--ink-soft);
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .cat-nav a:hover {
    color: var(--ink);
  }

  .cat-nav a.on {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  /* Mobil: dünne, einzeilige Leiste – Kategorien horizontal scrollbar
     (bewährtes Tab-/Chip-Pattern), Scrollbar ausgeblendet. */
  @media (max-width: 560px) {
    .head-inner {
      gap: 0.7rem;
      padding-top: 1.1rem;
      padding-bottom: 0.95rem;
    }
    .brand {
      font-size: 1.15rem;
    }
    .cat-nav {
      flex: 1 1 100%;
      flex-wrap: nowrap;
      overflow-x: auto;
      gap: 1.25rem;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-right: 0.5rem;
    }
    .cat-nav::-webkit-scrollbar {
      display: none;
    }
    .cat-nav a {
      flex: 0 0 auto;
      white-space: nowrap;
      font-size: 0.9rem;
    }
  }
</style>
