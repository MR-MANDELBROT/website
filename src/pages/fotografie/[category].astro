---
import { Image, getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { categories, getCategory, getPhotos } from "../../lib/gallery";

export function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.slug } }));
}

const { category } = Astro.params;
const cat = getCategory(category)!;
const photos = getPhotos(category);

// Größere, optimierte Variante für die Lightbox vorab erzeugen.
const items = await Promise.all(
  photos.map(async (p, i) => {
    const full = await getImage({
      src: p.img,
      widths: [1600],
      format: "webp",
    });
    return {
      img: p.img,
      full: full.src,
      ar: p.img.width / p.img.height, // Seitenverhältnis (Breite/Höhe)
      index: i,
    };
  }),
);

// In Zweier-Reihen gruppieren -> justiertes Layout, max. 2 nebeneinander.
const rows: (typeof items)[] = [];
for (let i = 0; i < items.length; i += 2) rows.push(items.slice(i, i + 2));
---

<BaseLayout
  title={`${cat.title} – Maximilian Marquart`}
  description={`${cat.title} – Fotografie von Maximilian Marquart.`}
>
  <SiteHeader active={cat.slug} />

  <main class="wrap">
    <section class="head">
      <h1>{cat.title}</h1>
      <span class="rule" aria-hidden="true"></span>
    </section>

    <section class="grid" id="grid">
      {
        rows.map((row) => (
          <div class:list={["row", { single: row.length === 1 }]}>
            {row.map((it) => (
              <button
                class="cell"
                type="button"
                style={`--ar:${it.ar.toFixed(4)}`}
                data-full={it.full}
                data-index={it.index}
                aria-label={`Bild ${it.index + 1} öffnen`}
              >
                <Image
                  src={it.img}
                  alt={`${cat.title} – Bild ${it.index + 1}`}
                  widths={[500, 800, 1100]}
                  sizes="(max-width: 560px) 100vw, 50vw"
                  loading={it.index < 6 ? "eager" : "lazy"}
                />
              </button>
            ))}
          </div>
        ))
      }
    </section>
  </main>

  <SiteFooter />

  <!-- Lightbox -->
  <div class="lb" id="lb" hidden aria-hidden="true">
    <button class="lb-close" id="lbClose" aria-label="Schließen">×</button>
    <button class="lb-nav lb-prev" id="lbPrev" aria-label="Vorheriges">‹</button>
    <img class="lb-img" id="lbImg" alt="" />
    <button class="lb-nav lb-next" id="lbNext" aria-label="Nächstes">›</button>
    <div class="lb-counter" id="lbCount"></div>
  </div>

  <script is:inline>
    (function () {
      var grid = document.getElementById("grid");
      var lb = document.getElementById("lb");
      var lbImg = document.getElementById("lbImg");
      var lbCount = document.getElementById("lbCount");
      var cells = Array.prototype.slice.call(
        grid.querySelectorAll(".cell"),
      );
      var srcs = cells.map(function (c) {
        return c.getAttribute("data-full");
      });
      var cur = 0;

      function show(i) {
        cur = (i + srcs.length) % srcs.length;
        lbImg.src = srcs[cur];
        lbCount.textContent = cur + 1 + " / " + srcs.length;
      }
      function open(i) {
        show(i);
        lb.hidden = false;
        lb.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      }
      function close() {
        lb.hidden = true;
        lb.setAttribute("aria-hidden", "true");
        lbImg.src = "";
        document.body.style.overflow = "";
      }

      cells.forEach(function (c, i) {
        c.addEventListener("click", function () {
          open(i);
        });
      });
      document.getElementById("lbClose").addEventListener("click", close);
      document.getElementById("lbNext").addEventListener("click", function () {
        show(cur + 1);
      });
      document.getElementById("lbPrev").addEventListener("click", function () {
        show(cur - 1);
      });
      lb.addEventListener("click", function (e) {
        if (e.target === lb) close();
      });
      document.addEventListener("keydown", function (e) {
        if (lb.hidden) return;
        if (e.key === "Escape") close();
        else if (e.key === "ArrowRight") show(cur + 1);
        else if (e.key === "ArrowLeft") show(cur - 1);
      });
    })();
  </script>
</BaseLayout>

<style>
  .head {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(1.25rem, 3vw, 2rem);
    max-width: 38rem;
  }
  .head h1 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    margin: 0;
    letter-spacing: -0.02em;
  }
  .head .rule {
    display: block;
    width: 44px;
    height: 1px;
    margin-top: 0.85rem;
    background: var(--ink);
    opacity: 0.55;
  }
  /* Justiertes Layout: max. 2 pro Reihe, beide gleich hoch, ohne Beschnitt,
     füllt die Breite komplett -> keine Lücken. Höhe ergibt sich aus den
     Seitenverhältnissen (--ar = Breite/Höhe) via flex-grow. */
  .grid {
    --gap: clamp(0.6rem, 1.5vw, 1rem);
    padding-bottom: 2rem;
  }
  .row {
    display: flex;
    gap: var(--gap);
    margin-bottom: var(--gap);
  }
  .row .cell {
    flex-grow: var(--ar);
    flex-basis: 0;
    min-width: 0;
  }
  /* Einzelnes Bild in letzter Reihe: nur halbe Breite, nicht riesig. */
  .row.single .cell {
    flex-grow: 0;
    flex-basis: calc(50% - var(--gap) / 2);
  }

  .cell {
    display: block;
    margin: 0;
    padding: 0;
    border: 0;
    background: #e9e7e1;
    border-radius: 8px;
    overflow: hidden;
    cursor: zoom-in;
    line-height: 0;
    /* eigene Compositing-Ebene: Rundung bleibt beim Hover-Zoom erhalten */
    transform: translateZ(0);
    will-change: transform;
  }
  .cell :global(img) {
    display: block;
    width: 100%;
    height: auto; /* gleiche Reihenhöhe ergibt sich automatisch */
    border-radius: inherit;
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1),
      opacity 0.3s ease;
  }
  .cell:hover :global(img) {
    transform: scale(1.03);
  }

  /* Mobil: gestapelt, ein Bild pro Reihe in natürlichem Format.
     flex zurücksetzen, sonst kollabieren die Zellen in Spaltenrichtung. */
  @media (max-width: 560px) {
    .row {
      flex-direction: column;
    }
    .row .cell {
      flex: none;
      width: 100%;
    }
  }

  /* Lightbox */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(12, 12, 14, 0.92);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    padding: clamp(1rem, 4vw, 3rem);
  }
  .lb[hidden] {
    display: none;
  }
  .lb-img {
    max-width: 100%;
    max-height: 88vh;
    margin: 0 auto;
    object-fit: contain;
    border-radius: 4px;
  }
  .lb-nav,
  .lb-close {
    background: none;
    border: 0;
    color: #fff;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }
  .lb-nav:hover,
  .lb-close:hover {
    opacity: 1;
  }
  .lb-nav {
    font-size: clamp(2rem, 6vw, 3rem);
    padding: 0 clamp(0.5rem, 2vw, 1.5rem);
    line-height: 1;
  }
  .lb-close {
    position: absolute;
    top: calc(clamp(0.5rem, 2vw, 1.25rem) + env(safe-area-inset-top, 0px));
    right: calc(clamp(0.75rem, 3vw, 1.75rem) + env(safe-area-inset-right, 0px));
    font-size: 2.2rem;
    line-height: 1;
  }
  .lb-counter {
    position: absolute;
    bottom: clamp(0.75rem, 3vw, 1.5rem);
    left: 50%;
    transform: translateX(-50%);
    color: #fff;
    opacity: 0.6;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
  }
  @media (max-width: 640px) {
    .lb-nav {
      position: absolute;
      bottom: 1rem;
      z-index: 2;
    }
    .lb-prev {
      left: 1rem;
    }
    .lb-next {
      right: 1rem;
    }
  }
</style>
