---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { categories, coverFor, getPhotos } from "../../lib/gallery";

const cards = categories.map((c) => ({
  ...c,
  cover: coverFor(c.slug),
  count: getPhotos(c.slug).length,
}));
---

<BaseLayout
  title="Fotografie – Maximilian Marquart"
  description="Foto-Portfolio von Maximilian Marquart: Professional Work, Portrait & Street, Landscape und Wildlife."
>
  <SiteHeader />

  <main class="wrap">
    <section class="intro">
      <h1>Fotografie</h1>
      <p class="sub">Eine Auswahl meiner Arbeit</p>
    </section>

    <section class="grid" aria-label="Kategorien">
      {
        cards.map((c) => (
          <a class="tile" href={`/fotografie/${c.slug}/`}>
            <div class="tile-img">
              {c.cover && (
                <Image
                  src={c.cover}
                  alt={c.title}
                  widths={[400, 800, 1200]}
                  sizes="(max-width: 720px) 100vw, 50vw"
                  loading="lazy"
                />
              )}
            </div>
            <div class="tile-meta">
              <h2>{c.title}</h2>
              <span class="count">{c.count} Bilder</span>
            </div>
          </a>
        ))
      }
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .intro {
    padding: clamp(2.5rem, 7vw, 5rem) 0 clamp(1.5rem, 4vw, 2.5rem);
    max-width: 38rem;
  }
  .intro h1 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(2rem, 6vw, 3rem);
    margin: 0 0 0.15rem;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .intro .sub {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.1rem, 3vw, 1.4rem);
    color: var(--ink-soft);
    letter-spacing: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    padding-bottom: 2rem;
  }
  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .tile {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .tile-img {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: var(--radius);
    background: #e9e7e1;
  }
  .tile-img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .tile:hover .tile-img :global(img) {
    transform: scale(1.04);
  }

  .tile-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.85rem;
  }
  .tile-meta h2 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.25rem;
    margin: 0;
  }
  .count {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    white-space: nowrap;
  }
</style>
